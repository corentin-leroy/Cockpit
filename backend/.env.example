# Copier ce fichier en .env et remplir les valeurs.
#
# En DÉVELOPPEMENT, tout est optionnel sauf JWT_SECRET_KEY : les défauts pointent
# sur SQLite et localhost, et les emails ne partent pas (mode DEV).
#
# En PRODUCTION (Railway), les variables se règlent dans l'onglet Variables du
# service — il n'y a pas de fichier .env déployé. Sont OBLIGATOIRES :
#   DATABASE_URL, JWT_SECRET_KEY, CORS_ORIGINS, FRONTEND_URL,
#   BREVO_API_KEY, BREVO_SENDER_EMAIL
# Seule BREVO_SENDER_NAME est facultative.


# =============================================================================
# Base de données  —  OBLIGATOIRE en production
# =============================================================================
# Le backend fonctionne avec SQLite ET PostgreSQL : c'est cette seule variable
# qui décide, aucun autre réglage n'est à changer.
#   - dev / tests (défaut si absente) : fichier SQLite local
#       DATABASE_URL=sqlite:///./cockpit.db
#   - production : PostgreSQL, via le driver psycopg v3
#       DATABASE_URL=postgresql+psycopg://utilisateur:motdepasse@hote:5432/nom_base
# Une URL d'hébergeur commençant par postgres:// (Railway, Heroku, Render…) est
# acceptée telle quelle : le backend la convertit automatiquement (database.py).
# Sur Railway, référencer la base plutôt que copier l'URL en dur :
#       DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=sqlite:///./cockpit.db


# =============================================================================
# Signature des JWT  —  OBLIGATOIRE (dev ET production)
# =============================================================================
# NE JAMAIS committer de vraie valeur, et utiliser une clé DIFFÉRENTE en prod.
# Générer une clé robuste :
#   py -c "import secrets; print(secrets.token_urlsafe(32))"
# Absente, l'app démarre mais toute connexion échoue (RuntimeError explicite).
# La changer invalide tous les tokens émis : les utilisateurs sont déconnectés.
JWT_SECRET_KEY=


# =============================================================================
# Origines autorisées (CORS)  —  OBLIGATOIRE en production
# =============================================================================
# Liste des origines autorisées à appeler l'API depuis un navigateur, séparées
# par des VIRGULES, SANS slash final (le navigateur envoie l'Origin sans slash) :
#   CORS_ORIGINS=https://cockpit.app,https://www.cockpit.app
# Absente, le défaut est http://localhost:5173 (Vite) : pratique en dev, mais en
# production le front déployé serait BLOQUÉ tant que son URL n'est pas ajoutée.
# Ajouter aussi l'origine de l'extension si elle appelle l'API depuis une page :
#   chrome-extension://<id_de_l_extension>
# CORS_ORIGINS=http://localhost:5173


# =============================================================================
# URL publique du front  —  OBLIGATOIRE en production
# =============================================================================
# Base des liens envoyés par email :
#   FRONTEND_URL/reset-password?token=...  et  FRONTEND_URL/verify-email?token=...
# Défaut si absente : http://localhost:5173 — en production, les liens de
# réinitialisation pointeraient donc vers la machine de l'utilisateur.
FRONTEND_URL=http://localhost:5173


# =============================================================================
# Emails transactionnels (Brevo)  —  OBLIGATOIRES en production
# =============================================================================
# https://app.brevo.com — clé API v3, et adresse expéditeur VALIDÉE dans Brevo
# (sinon les envois échouent).
# Si BREVO_API_KEY ou BREVO_SENDER_EMAIL est vide, le backend passe en MODE DEV :
# aucun email n'est envoyé, le lien est écrit dans les logs du serveur. En
# production, cela signifie que « mot de passe oublié » ne rend RIEN à
# l'utilisateur, sans la moindre erreur visible : à vérifier après déploiement.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
# Nom affiché comme expéditeur — facultatif (défaut : Cockpit)
# BREVO_SENDER_NAME=Cockpit


# =============================================================================
# Clés API (chantier 4, hors périmètre V1)
# =============================================================================
# Créer un compte sur https://francetravail.io
# FRANCE_TRAVAIL_CLIENT_ID=
# FRANCE_TRAVAIL_CLIENT_SECRET=
