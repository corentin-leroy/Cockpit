# Copier ce fichier en .env et remplir les valeurs
DATABASE_URL=sqlite:///./cockpit.db

# Clé secrète de signature des JWT — NE JAMAIS committer de vraie valeur.
# Générer une clé robuste :
#   py -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# URL publique du front : base des liens envoyés par email
# (FRONTEND_URL/reset-password?token=... et FRONTEND_URL/verify-email?token=...).
# Défaut si absente : http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Envoi d'emails transactionnels (Brevo) — https://app.brevo.com
# Clé API v3, et adresse expéditeur VALIDÉE dans Brevo (sinon les envois échouent).
# Si BREVO_API_KEY ou BREVO_SENDER_EMAIL est vide, le backend passe en MODE DEV :
# aucun email n'est envoyé, le lien est écrit dans les logs du serveur.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
# Nom affiché comme expéditeur (défaut : Cockpit)
# BREVO_SENDER_NAME=Cockpit

# Clés API (chantier 4) — créer un compte sur https://francetravail.io
# FRANCE_TRAVAIL_CLIENT_ID=
# FRANCE_TRAVAIL_CLIENT_SECRET=
