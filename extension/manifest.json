{
  "manifest_version": 3,
  "name": "Alternance Cockpit",
  "version": "0.1.0",
  "description": "Ajoute l'offre d'emploi affichée à ton cockpit en un clic.",

  "action": {
    "default_title": "Alternance Cockpit",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}
