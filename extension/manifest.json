{
  "manifest_version": 3,
  "name": "Cockpit",
  "version": "0.1.0",
  "description": "Suivez vos candidatures dans un kanban et capturez une offre depuis n'importe quel site d'annonces en un clic.",

  "action": {
    "default_title": "Cockpit",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}
